# ============================================================
#  XTREMEFIT — Backend production environment template
#  Copy to .env on the server, fill the blanks, then run:
#    php artisan key:generate
#    php artisan migrate --force --seed
#    php artisan storage:link
#    php artisan config:cache && php artisan route:cache
# ============================================================

APP_NAME=XtremeFit
APP_ENV=production
APP_KEY=
APP_DEBUG=false

# Public URL where this backend is reachable (https, no trailing slash)
APP_URL=https://api.your-domain.com
# Public URL of the deployed React frontend
APP_FRONTEND_URL=https://your-frontend.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app

# Frontend origin(s) allowed to call the API (comma-separated, no trailing slash)
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Database (from your host's MySQL panel) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# --- AI features (semantic search + virtual try-on) ---
# Use a key with a small monthly spend cap.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Google Maps (checkout map picker) ---
REACT_APP_GOOGLE_MAPS_KEY=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# --- File storage for uploads (product images, hero image/video) ---
# Option A (persistent-disk host, e.g. cPanel): leave these as-is.
FILESYSTEM_DRIVER=local
MEDIA_DISK=public
#
# Option B (Cloudflare R2 / any S3-compatible, recommended for PaaS hosts):
# set MEDIA_DISK=s3 and fill the block below. On the host (PHP 8.x) first run:
#   composer require league/flysystem-aws-s3-v3
# MEDIA_DISK=s3
# AWS_ACCESS_KEY_ID=            # R2 API token Access Key ID
# AWS_SECRET_ACCESS_KEY=        # R2 API token Secret Access Key
# AWS_DEFAULT_REGION=auto       # R2 uses "auto"
# AWS_BUCKET=xtremefit-media    # your R2 bucket name
# AWS_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# AWS_USE_PATH_STYLE_ENDPOINT=true
# AWS_URL=https://pub-xxxxxxxx.r2.dev   # the bucket's Public Development URL
#
# Then point the FRONTEND's REACT_APP_STORAGE_URL at AWS_URL (the R2 public URL),
# NOT at the backend /storage path.

# --- Outgoing mail (order + password-reset emails) ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# --- Permanent owner (super-admin that can never be demoted) ---
SUPER_ADMIN_EMAIL=admin@xtremefit.com
